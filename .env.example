# Salin file ini menjadi .env dan isi dengan data asli Anda
# JANGAN pernah commit file .env ke Git

# Alamat email pengirim
EMAIL_ADDRESS=your_email@gmail.com

# Password aplikasi Gmail (bukan password akun biasa)
# Cara membuat: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_PASSWORD=your_app_password_here

# SMTP Server Gmail
SMTP_SERVER=smtp.gmail.com

# Port SMTP (587 untuk TLS, 465 untuk SSL)
SMTP_PORT=587
